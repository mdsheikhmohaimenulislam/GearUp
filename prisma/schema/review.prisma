model Review {
  id        String  @id @default(uuid())
  rating    Int
  comment   String?

  userId    String
  user      User    @relation(fields: [userId], references: [id])

  gearId    String
  gear      GearItem @relation(fields: [gearId], references: [id])

   createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}